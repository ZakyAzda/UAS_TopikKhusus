# ============================================================================
# ecom-backend-go — Environment Variables Template
# Salin file ini ke .env dan isi nilainya sesuai environment kamu
# cp .env.example .env
# ============================================================================

# ─── Redis Cache ──────────────────────────────────────────────────────────────
# Gunakan REDIS_URL jika tersedia (prioritas utama), atau REDIS_HOST + REDIS_PORT
# Format REDIS_URL: redis://[:password@]host[:port][/db-number]
# Lokal tanpa password:
REDIS_URL=redis://localhost:6379
# Redis dengan password:
# REDIS_URL=redis://:yourpassword@localhost:6379
# Alternatif (jika tidak pakai REDIS_URL):
# REDIS_HOST=localhost
# REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# TTL default cache dalam detik (0 = pakai default 300 detik / 5 menit)
CACHE_TTL_SECONDS=300

# ─── Koneksi Database ─────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname?sslmode=disable
# Lokal:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecom?sslmode=disable
# Railway / Supabase / Neon (ganti dengan URL asli):
# DATABASE_URL=postgresql://user:password@host:port/database

# ─── Midtrans Payment Gateway ─────────────────────────────────────────────────
# Dapatkan server key dari: https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=Mid-server-XXXXXXXXXXXXXXXXXXXX
# Nilai: sandbox | production
MIDTRANS_ENV=sandbox

# ─── JWT Authentication ────────────────────────────────────────────────────────
# WAJIB diganti dengan random string 64+ karakter sebelum production!
# Generate: openssl rand -hex 32
JWT_SECRET=ganti-dengan-random-string-minimal-64-karakter-sebelum-production

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Python ML Server ─────────────────────────────────────────────────────────
# URL server Python untuk deteksi penyakit tanaman
# Lokal: http://localhost:8000
# Hugging Face: https://username-model-name.hf.space
ML_SERVER_URL=http://localhost:8000

# ─── WhatsApp (WAHA Gateway) ──────────────────────────────────────────────────
# Self-hosted WAHA server
WAHA_BASE_URL=http://localhost:3000
# Nomor WA admin dengan format: 628xxxxxxxxxx@c.us
ADMIN_WA_NUMBER=628xxxxxxxxxx@c.us
# API Key WAHA (lihat di dashboard WAHA kamu)
WAHA_API_KEY=your-waha-api-key

# ─── DEV ONLY ─────────────────────────────────────────────────────────────────
# ⚠️  WAJIB hapus endpoint /api/dev/make-admin sebelum production!
DEV_ADMIN_KEY=ganti-dengan-key-rahasia-dev
